# Slack App (api.slack.com/apps → 自分のアプリ)
SLACK_BOT_TOKEN=xoxb-...        # OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # Basic Information → App-Level Tokens (connections:write)

# 任意設定 (省略時は括弧内のデフォルト)
# MANAIGER_CODEX_PATH=codex     # Codex CLI のパス
# MANAIGER_CODEX_MODEL=...      # Codex App Server に渡すモデル (省略時は Codex 側設定)
# MANAIGER_HOME=~/.manaiger     # DB・ログの置き場所
# MANAIGER_WORK_START=09:00     # working hours 開始
# MANAIGER_WORK_END=18:00       # working hours 終了
# MANAIGER_INTERACTION_SPACING_MIN=20  # 連続 interaction の最小間隔
# MANAIGER_RECHECK_AFTER_MIN=30        # 未応答時の再確認までの時間
